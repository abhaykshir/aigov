# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment / secrets
.env
# Exception: test-fixture .env files must ship with the repo so the graph /
# scanner tests behave identically in CI. The values inside are intentionally
# fake (sk-fake-*) — see tests/fixtures/sample_graph_project/*/.env.
!tests/fixtures/**/.env
# Exception: example-project .env files. These ship with the repo so users can
# run aigov against the bundled examples/ directory and see the full pipeline.
# All values are deliberately fake placeholders — see examples/demo-project/.env.
!examples/**/.env

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Demo output
demo/
demo-compliance-docs/
demo-graph.html
.claude/

# Generated graph artifacts (aigov graph default output names)
aigov-graph.html
aigov-graph.json
